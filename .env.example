ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Resend (free at resend.com — Replit's official email partner)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email addresses
EMAIL_RECIPIENT=you@example.com
# EMAIL_FROM=News Aggregator <you@yourdomain.com>
# Leave EMAIL_FROM unset to use onboarding@resend.dev (no domain verification needed)

# X / Twitter API — Bearer Token (free tier at developer.twitter.com)
# Required to fetch @BaltimoreBanner tweets. Leave blank to skip Twitter.
TWITTER_BEARER_TOKEN=
